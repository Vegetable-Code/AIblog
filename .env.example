# Railway 部署说明
# 
# 在 Railway Dashboard 中设置以下环境变量：
#
# 1. 使用 Railway MySQL 插件后，设置：
#    DATABASE_URL=mysql+pymysql://<user>:<pass>@<host>:<port>/<db>
#
# 2. 密钥配置：
#    SECRET_KEY=<生成一个随机字符串>
#
# 3. 其他配置（使用默认值即可）：
#    ALGORITHM=HS256
#    ACCESS_TOKEN_EXPIRE_MINUTES=1440
#
# 部署步骤：
# 1. 安装 Railway CLI: npm i -g @railway/cli
# 2. 登录: railway login
# 3. 链接项目: railway link
# 4. 添加 MySQL: railway add mysql
# 5. 部署: railway up
# 6. 设置域名: railway domain

DATABASE_URL=mysql+pymysql://root:password@localhost:3306/blog_db
SECRET_KEY=your-secret-key-change-in-production-abc123xyz
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
